{
  "name": "telegram-bot-admin",
  "version": "1.0.0",
  "description": "Telegram Bot Admin Interface",
  "homepage": "https://denis90-ctrl.github.io/bot2v",
  "scripts": {
    "install:backend": "cd backend && npm install",
    "install:admin": "cd admin && npm install",
    "install:all": "npm run install:backend && npm run install:admin",
    "start:backend": "cd backend && npm start",
    "start:admin": "cd admin && npm start",
    "dev:backend": "cd backend && npm run dev",
    "dev:admin": "cd admin && npm start",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:admin\"",
    "build:admin": "cd admin && npm run build",
    "setup-webhook": "node scripts/setup-webhook.js",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.10"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
